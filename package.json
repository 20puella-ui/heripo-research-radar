{
  "name": "@heripo/research-radar",
  "private": false,
  "type": "module",
  "version": "3.1.3",
  "description": "AI-driven intelligence for Korean cultural heritage. This package serves as both a ready-to-use newsletter service and a practical implementation example for the LLM-Newsletter-Kit.",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "sideEffects": false,
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && rollup -c",
    "prepublishOnly": "npm run build",
    "preversion": "npm run build",
    "postversion": "git push --follow-tags",
    "release": "npm publish --access public",
    "release:patch": "npm version patch && npm publish --access public",
    "release:minor": "npm version minor && npm publish --access public",
    "release:major": "npm version major && npm publish --access public",
    "lint": "eslint ./src",
    "lint:fix": "eslint --fix ./src",
    "lint:ci": "eslint --quiet ./src",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md,mdx}\"",
    "dev:crawler": "tsx watch dev-tools/crawler-debugger/server.ts",
    "dev:crawler:proxy": "tsx watch --env-file=dev-tools/crawler-debugger/.env dev-tools/crawler-debugger/server.ts",
    "dev:newsletter-preview": "tsx watch dev-tools/newsletter-preview/server.ts",
    "dev:welcome-preview": "tsx watch dev-tools/welcome-preview/server.ts",
    "health-check": "tsx dev-tools/health-check/index.ts",
    "health-check:proxy": "tsx --env-file=dev-tools/crawler-debugger/.env dev-tools/health-check/index.ts --proxy"
  },
  "author": "kimhongyeon",
  "license": "Apache-2.0",
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/openai": "^3.0.41",
    "cheerio": "^1.2.0",
    "dompurify": "^3.3.3",
    "jsdom": "^29.0.0",
    "juice": "^11.1.1",
    "safe-markdown2html": "^1.0.1",
    "turndown": "^7.2.2"
  },
  "peerDependencies": {
    "@llm-newsletter-kit/core": "~1.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@llm-newsletter-kit/core": "^1.3.7",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/express": "^5.0.6",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^25.5.0",
    "@types/turndown": "^5.0.6",
    "eslint": "^10.0.3",
    "eslint-plugin-unused-imports": "^4.4.1",
    "express": "^5.2.1",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "rollup": "^4.59.0",
    "rollup-plugin-dts": "^6.4.0",
    "rollup-plugin-typescript2": "^0.36.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/heripo-lab/heripo-research-radar"
  },
  "bugs": {
    "url": "https://github.com/heripo-lab/heripo-research-radar/issues"
  },
  "homepage": "https://heripo.com",
  "keywords": [
    "cultural-heritage",
    "archaeology",
    "art-history",
    "korean-heritage",
    "museum",
    "heripo",
    "research-radar",
    "llm-newsletter-kit",
    "newsletter",
    "ai-newsletter",
    "research-automation",
    "intelligence",
    "data-analysis",
    "excavation",
    "driver",
    "example"
  ],
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public"
  }
}
